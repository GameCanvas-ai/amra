{
  "expo": {
    "name": "Amra",
    "slug": "amra",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "amra",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.amra.lore"
    },
    "android": {
      "package": "app.amra.lore",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41c7daf8-54f8-4b5a-8f93-ada5a91d7d0f"
      }
    },
    "owner": "gamecanvasai"
  }
}
